<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KickDropsMiner_WinUI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="CampaignTemplate">
            <Grid Padding="12,8" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="5" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Image Source="{Binding GameImage}" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Game}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Creator}" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding Drop}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Status}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding Time}" />
                <Button Grid.Column="4" MinWidth="82" VerticalAlignment="Center" Click="AddCampaign_Click" Content="+ Add" Tag="{Binding}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="32" FontWeight="SemiBold" Text="Browse Drops" />
                <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Refresh to load active Kick drops." />
            </StackPanel>
            <ProgressRing x:Name="LoadProgress" Grid.Column="1" Width="28" Height="28" IsActive="False" Visibility="Collapsed" />
            <Button Grid.Column="2" MinWidth="120" Click="Refresh_Click" Content="Load Drops" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <ComboBox
            x:Name="AccountPicker"
            Grid.Row="1"
            DisplayMemberPath="Name"
            Header="Account"
            MinWidth="240" />

        <ProgressBar
            x:Name="LoadBar"
            Grid.Row="2"
            Height="4"
            IsIndeterminate="False"
            Maximum="100"
            Minimum="0"
            Visibility="Collapsed" />

        <Grid Grid.Row="3" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Padding="10,0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Game" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Creator" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Drop" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontWeight="SemiBold" Text="Time" />
                <TextBlock Grid.Column="4" VerticalAlignment="Center" FontWeight="SemiBold" Text="Action" />
            </Grid>
            <ListView
                x:Name="CampaignList"
                Grid.Row="1"
                ItemTemplate="{StaticResource CampaignTemplate}"
                SelectionMode="None" />
        </Grid>
    </Grid>
</Page>
